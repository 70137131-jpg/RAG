# ─────────────────────────────────────────────────────────────
# RAG Chatbot — environment configuration
# Copy this file to `.env` and fill in the values you need.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ── LLM provider (pick ONE) ──────────────────────────────────
# The app runs fully offline (extractive answers) with NO key set.
# Add a key below to enable real LLM-generated answers.

# Google Gemini (free tier: https://aistudio.google.com/apikey)
GOOGLE_API_KEY=

# OpenAI-compatible providers (uncomment the one you use)
# OPENAI_API_KEY=sk-...
# OPENROUTER_API_KEY=sk-or-v1-...
# DEEPSEEK_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1

# ── Model / generation ───────────────────────────────────────
# Gemini: gemini-2.5-flash (default), gemini-2.5-pro, gemini-2.0-flash
# OpenAI: gpt-4o-mini, gpt-4o, etc.
LLM_MODEL=gemini-2.5-flash
TEMPERATURE=0.1
MAX_TOKENS=300
TOP_K=3

# ── Vector store / embeddings ────────────────────────────────
COLLECTION_NAME=squad_contexts
PERSIST_DIRECTORY=./chroma_db
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHUNK_SIZE=500
CHUNK_OVERLAP=50
# Optional cross-encoder reranker (slower, more accurate):
# RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ── Dataset ──────────────────────────────────────────────────
DATASET_NAME=squad_v2
DATASET_SPLIT=validation
MAX_SAMPLES=100

# ── Web server ───────────────────────────────────────────────
PORT=5000
# Set to "development" to enable Flask debug mode (do NOT use in production)
FLASK_ENV=production
# Session signing key — REQUIRED for production. Generate one with:
#   python3 -c "import os; print(os.urandom(32).hex())"
SECRET_KEY=

# ── API hardening ────────────────────────────────────────────
# Max JSON payload size accepted by Flask.
REQUEST_MAX_BYTES=16384
# Max user question length in characters.
MAX_QUESTION_LENGTH=2000
# Basic per-client in-process query limit. Set RATE_LIMIT_REQUESTS=0 to disable.
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60
# Optional token protecting /api/stats and /metrics. Send as X-Admin-Token
# or Authorization: Bearer <token>.
ADMIN_TOKEN=
# Keep false for plain localhost HTTP. Set true behind HTTPS in production.
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=Lax
